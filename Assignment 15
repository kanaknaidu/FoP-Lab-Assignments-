Write a C program to generate pseudo random numbers.

#include <stdio.h>
#include <stdlib.h>
#include <time.h>

int main() {
    int i;

    srand(time(0));  // seed for randomness

    printf("Random Numbers:\n");

    for(i = 1; i <= 5; i++) {
        printf("%d\n", rand() % 100);  // numbers between 0–99
    }

    return 0;
}
