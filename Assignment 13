Write a program in C to accept a number from the user and print the digits of the number in reverse order.

#include <stdio.h>

int main() {
    int n, rem;

    printf("Enter a number: ");
    scanf("%d", &n);

    printf("Reversed number: ");

    while(n != 0) {
        rem = n % 10;
        printf("%d", rem);
        n = n / 10;
    }

    return 0;
}
