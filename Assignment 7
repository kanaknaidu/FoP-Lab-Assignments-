Write a C program to accept student details and display their result using an array of structures.

#include <stdio.h>

struct student {
    int roll;
    char name[50];
    float marks;
};

int main() {
    struct student s[5];
    int i;

    // Input
    for(i = 0; i < 5; i++) {
        printf("\nEnter Roll, Name, Marks: ");
        scanf("%d %s %f", &s[i].roll, s[i].name, &s[i].marks);
    }

    // Output
    printf("\n--- Student Result ---\n");
    for(i = 0; i < 5; i++) {
        printf("Roll: %d Name: %s Marks: %.2f ",
               s[i].roll, s[i].name, s[i].marks);

        if(s[i].marks >= 40)
            printf("PASS\n");
        else
            printf("FAIL\n");
    }

    return 0;
}
