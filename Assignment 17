To accept the number of terms and find the sum of the sine series.

#include <stdio.h>
#include <math.h>

int main() {
    int n, i;
    float x, term, sum = 0, fact;

    printf("Enter value of x (in radians): ");
    scanf("%f", &x);

    printf("Enter number of terms: ");
    scanf("%d", &n);

    for(i = 0; i < n; i++) {
        fact = 1;
        int j;
        for(j = 1; j <= (2*i+1); j++)
            fact *= j;

        term = pow(-1, i) * pow(x, 2*i+1) / fact;
        sum += term;
    }

    printf("Sum of sine series = %.4f", sum);

    return 0;
}
