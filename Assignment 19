Create Structure EMPLOYEE for storing details (Name, Designation, gender, Date of Joining and Salary). Define function members to compute a) total number of employees in an organization b) count of male and female employee c) Employee with salary more than 10,000 d) Employee with designation “Asst Manager”


#include <stdio.h>
#include <string.h>

struct EMPLOYEE {
    char name[50], desig[50], gender;
    int day, month, year;
    float salary;
};

// a) Total employees
void total(int n) {
    printf("Total Employees = %d\n", n);
}

// b) Count male & female
void countGender(struct EMPLOYEE e[], int n) {
    int m=0,f=0,i;
    for(i=0;i<n;i++) {
        if(e[i].gender=='M' || e[i].gender=='m') m++;
        else f++;
    }
    printf("Male = %d, Female = %d\n", m, f);
}

// c) Salary > 10000
void highSalary(struct EMPLOYEE e[], int n) {
    int i;
    printf("Employees with salary > 10000:\n");
    for(i=0;i<n;i++)
        if(e[i].salary > 10000)
            printf("%s\n", e[i].name);
}

// d) Asst Manager
void asstManager(struct EMPLOYEE e[], int n) {
    int i;
    printf("Asst Managers:\n");
    for(i=0;i<n;i++)
        if(strcmp(e[i].desig,"Asst Manager")==0)
            printf("%s\n", e[i].name);
}

int main() {
    struct EMPLOYEE e[50];
    int n,i;

    printf("Enter number of employees: ");
    scanf("%d",&n);

    for(i=0;i<n;i++) {
        printf("\nEnter Name, Designation, Gender, DOJ(dd mm yyyy), Salary:\n");
        scanf("%s %s %c %d %d %d %f",
              e[i].name, e[i].desig, &e[i].gender,
              &e[i].day, &e[i].month, &e[i].year,
              &e[i].salary);
    }

    total(n);
    countGender(e,n);
    highSalary(e,n);
    asstManager(e,n);

    return 0;
}
