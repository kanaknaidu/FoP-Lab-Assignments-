Write a program in C to check whether the given number is an Armstrong number or not.

#include <stdio.h>

int main() {
    int num, temp, rem, sum = 0;

    printf("Enter a 3-digit number: ");
    scanf("%d", &num);

    temp = num;

    while(temp != 0) {
        rem = temp % 10;
        sum += rem * rem * rem;
        temp /= 10;
    }

    if(sum == num)
        printf("Armstrong Number");
    else
        printf("Not an Armstrong Number");

    return 0;
}
