Write a program in C to simulate a simple calculator that performs basic arithmetic operations such as addition, subtraction, multiplication, and division. The calculator should also perform special operations like computing xʸ (power) and x! (factorial).

#include <stdio.h>

int main() {
    int ch, i, n;
    float a, b, result = 1;

    printf("1.Add 2.Sub 3.Mul 4.Div 5.Power 6.Factorial\n");
    scanf("%d", &ch);

    switch(ch) {

    case 1:
        scanf("%f%f",&a,&b);
        printf("Result=%.2f", a+b);
        break;

    case 2:
        scanf("%f%f",&a,&b);
        printf("Result=%.2f", a-b);
        break;

    case 3:
        scanf("%f%f",&a,&b);
        printf("Result=%.2f", a*b);
        break;

    case 4:
        scanf("%f%f",&a,&b);
        if(b!=0) printf("Result=%.2f", a/b);
        else printf("Error");
        break;

    case 5: // Power
        scanf("%f%f",&a,&b);
        result = 1;
        for(i=1;i<=b;i++)
            result *= a;
        printf("Result=%.2f", result);
        break;

    case 6: // Factorial
        scanf("%d",&n);
        result = 1;
        for(i=1;i<=n;i++)
            result *= i;
        printf("Result=%.0f", result);
        break;

    default:
        printf("Invalid");
    }

    return 0;
}
