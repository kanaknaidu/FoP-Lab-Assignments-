Write a C program to input a binary number from the user and convert it into a decimal number.

#include <stdio.h>
#include <math.h>

int main() {
    int bin, rem, i = 0;
    int dec = 0;

    printf("Enter a binary number: ");
    scanf("%d", &bin);

    while(bin != 0) {
        rem = bin % 10;
        dec += rem * pow(2, i);
        bin /= 10;
        i++;
    }

    printf("Decimal = %d", dec);

    return 0;
}
